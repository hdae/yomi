{
  "name": "@hdae/yomi",
  "version": "0.2.0",
  // 公開 API。コア（.）はモデル非依存の中立 G2P の薄いファサード。細粒度の言語モデルは
  // リファレンス実装（jpreprocess/pyopenjtalk）に倣いドメイン別サブパスで公開する。
  // JTD1 コーデックは /format、ブラウザ辞書ローダは /browser。モデル固有アダプタは持たない
  // （docs/decisions/0001）。
  "exports": {
    ".": "./src/mod.ts",
    "./text": "./src/text/mod.ts",
    "./dict": "./src/dict/mod.ts",
    "./tokenizer": "./src/tokenizer/mod.ts",
    "./njd": "./src/njd/mod.ts",
    "./g2p": "./src/g2p/mod.ts",
    "./format": "./src/format/mod.ts",
    "./browser": "./src/browser/mod.ts"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check . && deno test --allow-read --allow-env",
    // --allow-read: version 焼き込みの drift ガード(version_sync)と実辞書統合テストが読取に使う
    //   （辞書 fixture が無ければ統合テストは skip・ci.yml と同じ権限）。--allow-env: YOMI_DICT_PATH 用。
    "test": "deno test --allow-read --allow-env",
    "fmt": "deno fmt",
    // naist-jdic → JTD1 を生成し fixtures/naist-jdic.jtd に出力（統合テストの既定辞書）。
    "build-dict": "deno run -A dict-builder/src/build.ts",
    // 性能ベンチ（dev 用・CI の pass/fail に使わない。scripts/tokenize_bench.ts 参照）。
    "bench": "deno bench --allow-read --allow-env scripts/",
    // version を bump（例: deno task bump patch）。組込み deno bump-version で deno.jsonc の version を
    // 更新し、焼き込み src/constants.ts も同じ版へ surgical 更新して、2ファイルを1コミットにする（tag/push はしない）。
    "bump": "deno run --allow-read --allow-run=deno,git --allow-write=src/constants.ts --no-lock scripts/bump.ts"
  },
  "imports": {
    "@hdae/yomi": "./src/mod.ts",
    // dev/CI 用（scripts/ の deno.jsonc 解析）。配布パッケージ src/ は import しない＝実行時依存ゼロは不変。
    "@std/jsonc": "jsr:@std/jsonc@^1.0.2"
  },
  "fmt": {
    "lineWidth": 100,
    "proseWrap": "preserve",
    "exclude": ["**/*.md"]
  },
  "lint": {
    "exclude": ["fixtures/"]
  },
  "publish": {
    // テスト・テスト専用ヘルパ・辞書バイナリ・golden は配布物に含めない。
    "include": ["src/", "deno.jsonc", "README.md", "LICENSE", "NOTICE"],
    "exclude": ["src/**/*.test.ts", "src/_dict_path.ts"]
  },
  // dict-builder（辞書ビルダ）・生成物・辞書データ・レビュー成果物はパッケージの check/test/fmt/lint 対象外。
  // NOTE: fmt/lint の glob `**` はドット始まりディレクトリに合致しないため .claude/ は明示除外が必要。
  "exclude": [
    "dict-builder/",
    "fixtures/",
    "data/",
    ".claude/"
  ]
}
